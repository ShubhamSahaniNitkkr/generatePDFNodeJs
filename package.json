{
  "name": "generate-pdf-nodejs",
  "version": "1.0.0",
  "description": "Dynamic PDF invoice generator with React UI",
  "main": "server.js",
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "ui": "npm start --prefix ui",
    "uiinstall": "npm install --prefix ui",
    "build:ui": "npm run build --prefix ui",
    "build": "npm run uiinstall && npm run build:ui",
    "build:ui-local": "npm run build --prefix ui",
    "demo": "npm run build:ui-local && SERVE_UI=true node server.js",
    "dev": "concurrently \"npm run server\" \"npm run ui\""
  },
  "dependencies": {
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "nodemon": "^2.0.2",
    "puppeteer": "^25.1.0"
  },
  "devDependencies": {
    "concurrently": "^5.0.1"
  }
}
